# Notion-GitHub Sync Configuration
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# NOTION API
# ============================================================================
# Notion Integration API Key (required)
# Get from: https://www.notion.com/my-integrations
# Current workflow uses: NOTION_TOKEN
NOTION_TOKEN=your_notion_api_key_here

# Notion Database ID to sync from (required)
# Format: 32-character hex string (e.g., abc123def456...)
# Get from: Open database in Notion, copy ID from URL
NOTION_DATABASE_ID_CHANGES=your_notion_db_id_here

# ============================================================================
# GITHUB API
# ============================================================================
# GitHub Personal Access Token (required)
# Current workflow uses: GH_PAT
#
# Get from: https://github.com/settings/tokens
# Required scopes: repo (full repository access), issues (required for issue creation)
GH_PAT=your_github_pat_here

# GitHub Repository (required)
# Format: owner/repo (e.g., username/repository-name)
# Can also be specified in config/notion_map.json
GITHUB_REPO=owner/repo

# ============================================================================
# SCRIPT CONFIGURATION (optional)
# ============================================================================
# Path to configuration file (defaults to config/notion_map.json)
# CONFIG_PATH=config/notion_map.json

# Working directory for logs (defaults to logs/)
# LOG_DIR=logs/

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with real credentials to version control
# 2. Use GitHub encrypted secrets for CI/CD pipelines
# 3. Notion API keys never expire, but rotate them regularly for security
# 4. GitHub PAT tokens expire after configurable period (default: 90 days)
# 5. Token validation is performed before sync execution
# 6. These variable names match the GitHub Actions workflow in .github/workflows/
